# web/.env.example — copy to .env.local and tune for local dev.
#
# All vars are OPTIONAL. The open-source defaults run against a
# localhost API with the generic "OpenPerimetry" identity.

# ── API endpoint ──────────────────────────────────────────────────
# Leave empty for same-origin relative fetches. Set to the API URL
# when running the frontend and API on different hosts.
VITE_API_URL=

# ── Branding ──────────────────────────────────────────────────────
# Rebrand a fork by setting these. Defaults to "OpenPerimetry" at
# localhost. All vars fall back cleanly when unset.
# VITE_APP_NAME=OpenPerimetry
# VITE_APP_URL=http://localhost:5173
# VITE_APP_DOMAIN=openperimetry.org
# VITE_SUPPORT_EMAIL=
# VITE_CONTACT_EMAIL=
# VITE_APP_VERSION=dev

# Show the creator-bio "About" page. Default: false (open-source builds
# hide it). Set to "true" in hosted builds that want the page visible.
# VITE_SHOW_ABOUT_PAGE=false

# ── Analytics (all optional) ──────────────────────────────────────
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
VITE_UMAMI_HOST_URL=
VITE_UMAMI_DOMAINS=
VITE_MSADS_UET_TAG_ID=
