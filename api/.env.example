# api/.env.example — copy to .env and tune for local dev.
#
# The open-source defaults run an sqlite-backed API on port 8787 with
# a console-only email backend. No AWS credentials required.

# ── Runtime ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787

# ── Frontend CORS ──────────────────────────────────────────────────
# Comma-separated list. Add production origins for hosted builds.
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_PUBLIC_URL=http://localhost:5173
TRUST_PROXY_HOPS=1

# ── Auth cookies ───────────────────────────────────────────────────
AUTH_COOKIE_NAME=op_session
# AUTH_COOKIE_SECURE defaults to true in production; set to false for local http.
# AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_MS=604800000   # 7 days in ms
SESSION_TTL_MS=604800000           # 7 days in ms

# ── Rate limits (requests per window) ─────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_REGISTER=8
RATE_LIMIT_LOGIN=20
RATE_LIMIT_CONTACT=5

# ── Storage backend ───────────────────────────────────────────────
# "sqlite" is the default for local dev; "dynamodb" is an optional
# production backend that requires AWS credentials and the ddbStore
# module (the open-source distribution includes only sqlite).
STORAGE_BACKEND=sqlite
SQLITE_DB_PATH=./data/local.sqlite

# DynamoDB — only used when STORAGE_BACKEND=dynamodb.
# AWS_REGION=eu-west-1
# DDB_USERS_TABLE=op-users
# DDB_SESSIONS_TABLE=op-sessions
# DDB_VF_RESULTS_TABLE=op-vf-results
# DDB_EVENTS_TABLE=op-events
# DDB_RATE_LIMITS_TABLE=op-rate-limits

# ── Email backend ─────────────────────────────────────────────────
# "console" prints messages to stdout (default for local dev);
# "ses" sends via AWS SESv2 (requires SES_REGION + verified domain).
EMAIL_BACKEND=console
# SES_REGION=us-east-1
# EMAIL_FROM_ADDRESS=noreply@example.com
# SUPPORT_EMAIL=support@example.com
# CONTACT_RECIPIENT=you@example.com
